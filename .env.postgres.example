APP_ENV=local
USE_POSTGRES=true

# Optional. If DATABASE_URL is set, it overrides calculated URL.
# DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/web_api_automation_dev

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=web_api_automation_dev
POSTGRES_TEST_DB=web_api_automation_test

# Optional explicit test URL. Used when APP_ENV=test.
# TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/web_api_automation_test
